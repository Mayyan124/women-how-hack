        <div class="code-box">
            <div class="code-label">C# — if, else if, else</div>
            <pre><span class="code-keyword">using</span> System;

<span class="code-keyword">class</span> Program
{
    <span class="code-keyword">static void</span> Main()
    {
        <span class="code-keyword">int</span> score = 85;

        <span class="code-keyword">if</span>(score >= 90)
        {
            Console.WriteLine(<span class="code-string">"A"</span>);
        }
        <span class="code-keyword">else if</span>(score >= 80)
        {
            Console.WriteLine(<span class="code-string">"B"</span>);
        }
        <span class="code-keyword">else</span>
        {
            Console.WriteLine(<span class="code-string">"C"</span>);
        }
    }
}

<span class="code-comment">// פלט:</span>
<span class="code-output">B</span></pre>
