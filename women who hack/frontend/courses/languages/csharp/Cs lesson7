<script>
    document.getElementById('hamburger').onclick=function(){document.getElementById('nav-links').classList.toggle('open');};
        const feedbacks={
        q1:{ok:'✅ נכון! % = מודולוס, מחזיר שארית חילוק.',no:'❌ לא. % הוא מודולוס — מחזיר את שארית החילוק.'},
        q2:{ok:'✅ נכון! חילוק int ב-int תמיד מחזיר מספר שלם.',no:'❌ לא. כשמחלקים int ב-int התוצאה תמיד שלמה — 3.'},
        q3:{ok:'✅ נכון! 10 מתחלק ב-2 בדיוק, שארית = 0.',no:'❌ לא. 10 % 2 = 0 כי 10 מתחלק ב-2 בדיוק.'},
        q4:{ok:'✅ נכון! חילוק באפס גורם ל-Exception.',no:'❌ לא. חילוק באפס גורם לשגיאה (Exception).'},
        q5:{ok:'✅ נכון! number % 2 == 0 בודק זוגיות.',no:'❌ לא. הדרך לבדוק זוגיות: number % 2 == 0.'},
    };
    const answers={};
    function answer(btn,q,correct,label){
        const btns=btn.closest('.quiz-options').querySelectorAll('.quiz-btn');
        btns.forEach(b=>b.disabled=true);
        btn.classList.add(correct?'correct':'wrong');
        answers[q]=correct;
        const fb=document.getElementById('fb-'+q);
        fb.textContent=correct?feedbacks[q].ok:feedbacks[q].no;
        fb.className='quiz-feedback show '+(correct?'ok':'no');
    }
    function showScore(){
        const score=Object.values(answers).filter(Boolean).length;
        const el=document.getElementById('quiz-score');
        el.innerHTML='<h3>'+(score===5?'🏆':score>=4?'⭐':score>=3?'💪':'📚')+' '+score+'/5</h3><p>'+(score===5?'מושלם!':score>=3?'יפה! חזרי על החומר.':'בואי נקרא שוב 💪')+'</p>';
        el.style.display='block';
        el.scrollIntoView({behavior:'smooth'});
    }
    document.querySelectorAll('.lesson-nav a').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth'});document.querySelectorAll('.lesson-nav a').forEach(x=>x.classList.remove('active'));this.classList.add('active');});});
</script>
</body>
</html>
