        <div class="code-box">
            <div class="code-label">C# — Mathematical Operators</div>
            <pre><span class="code-keyword">using</span> System;

<span class="code-keyword">class</span> Program
{
    <span class="code-keyword">static void</span> Main()
    {
        <span class="code-keyword">int</span> a = 10;
        <span class="code-keyword">int</span> b = 3;

        Console.WriteLine(a + b);  <span class="code-comment">// 13</span>
        Console.WriteLine(a - b);  <span class="code-comment">// 7</span>
        Console.WriteLine(a * b);  <span class="code-comment">// 30</span>
        Console.WriteLine(a / b);  <span class="code-comment">// 3 (שלם!)</span>
        Console.WriteLine(a % b);  <span class="code-comment">// 1 (שארית)</span>

        <span class="code-comment">// בדיקת זוגיות</span>
        <span class="code-keyword">int</span> number = 8;
        Console.WriteLine(number % 2); <span class="code-comment">// 0 = זוגי</span>
    }
}</pre>
        </div>
