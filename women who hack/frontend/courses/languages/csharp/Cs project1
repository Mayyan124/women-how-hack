        <span class="code-keyword">int</span> age = int.Parse(Console.ReadLine());

        <span class="code-comment">// הדפסת פרופיל</span>
        Console.WriteLine(<span class="code-string">"===================="</span>);
        Console.WriteLine(<span class="code-string">"USER PROFILE"</span>);
        Console.WriteLine(<span class="code-string">"===================="</span>);
        Console.WriteLine(<span class="code-string">"Name: "</span> + name);
        Console.WriteLine(<span class="code-string">"Age:  "</span> + age);
        Console.WriteLine(<span class="code-string">"===================="</span>);
        Console.WriteLine(<span class="code-string">"Hello "</span> + name + <span class="code-string">", you are "</span> + age + <span class="code-string">" years old!"</span>);
    }
}

