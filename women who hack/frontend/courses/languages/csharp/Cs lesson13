    document.getElementById('hamburger').onclick=function(){document.getElementById('nav-links').classList.toggle('open');};
        const feedbacks={
        q1:{ok:'✅ נכון! אלגוריתם = סדרת צעדים.',no:'❌ לא. אלגוריתם הוא סדרת צעדים ברורים לפתרון בעיה.'},
