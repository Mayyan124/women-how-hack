            <pre><span class="code-keyword">using</span> System;

<span class="code-keyword">class</span> Program
{
    <span class="code-keyword">static void</span> Main()
    {
        <span class="code-keyword">bool</span> a = <span class="code-keyword">true</span>;
        <span class="code-keyword">bool</span> b = <span class="code-keyword">false</span>;

        Console.WriteLine(a && b);  <span class="code-comment">// false</span>
        Console.WriteLine(a || b);  <span class="code-comment">// true</span>
        Console.WriteLine(!a);      <span class="code-comment">// false</span>
        Console.WriteLine(!b);      <span class="code-comment">// true</span>

        <span class="code-comment">// שימוש עם משתנים</span>
        <span class="code-keyword">int</span> age = 20;
        <span class="code-keyword">bool</span> hasTicket = <span class="code-keyword">true</span>;
        Console.WriteLine(age >= 18 && hasTicket); <span class="code-comment">// true</span>
    }
}</pre>
