<script>
    document.getElementById('hamburger').onclick=function(){document.getElementById('nav-links').classList.toggle('open');};
        const feedbacks={
        q1:{ok:'✅ נכון! && = AND, נכון רק אם שניהם נכון.',no:'❌ לא. && הוא AND — נכון רק אם שני הצדדים נכונים.'},
        q2:{ok:'✅ נכון! true && false = false.',no:'❌ לא. AND דורש ששניהם יהיו true. true && false = false.'},
        q3:{ok:'✅ נכון! OR מחזיר true אם לפחות אחד true.',no:'❌ לא. || = OR, מחזיר true אם לפחות אחד true.'},
        q4:{ok:'✅ נכון! !true = false.',no:'❌ לא. ! הופך את הערך. !true = false.'},
        q5:{ok:'✅ נכון! || מחזיר false רק כששניהם false.',no:'❌ לא. || מחזיר false רק כששני הצדדים false.'},
    };
    const answers={};
    function answer(btn,q,correct){const btns=btn.closest('.quiz-options').querySelectorAll('.quiz-btn');btns.forEach(b=>b.disabled=true);btn.classList.add(correct?'correct':'wrong');answers[q]=correct;const fb=document.getElementById('fb-'+q);fb.textContent=correct?feedbacks[q].ok:feedbacks[q].no;fb.className='quiz-feedback show '+(correct?'ok':'no');}
    function showScore(){const score=Object.values(answers).filter(Boolean).length;const el=document.getElementById('quiz-score');el.innerHTML='<h3>'+(score===5?'🏆':score>=4?'⭐':score>=3?'💪':'📚')+' '+score+'/5</h3><p>'+(score===5?'מושלם!':score>=3?'יפה! חזרי על החומר.':'בואי נקרא שוב 💪')+'</p>';el.style.display='block';el.scrollIntoView({behavior:'smooth'});}
    document.querySelectorAll('.lesson-nav a').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth'});document.querySelectorAll('.lesson-nav a').forEach(x=>x.classList.remove('active'));this.classList.add('active');});});
