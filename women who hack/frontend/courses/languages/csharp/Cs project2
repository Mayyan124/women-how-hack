    <div class="section-card">
        <h2>💡 הסבר — איך לבצע</h2>
        <p>
        <strong>שלב 1:</strong> קבעי מספר קבוע (targetNumber = 42) — לא אקראי כי עוד לא למדנו Random.<br><br>
        <strong>שלב 2:</strong> הגדירי משתנה guess = 0 ו-attempts = 0.<br><br>
        <strong>שלב 3:</strong> לולאת while(guess != targetNumber) — ממשיכה עד ניחוש נכון.<br><br>
        <strong>שלב 4:</strong> בכל סיבוב: קראי ניחוש, הגדלי attempts, ובדקי עם if אם גבוה/נמוך/נכון.<br><br>
        <strong>שלב 5:</strong> אחרי הלולאה — הדפיסי כמה ניחושים לקח.
        </p>
    </div>
    <div class="section-card">
        <h2>🔑 קוד הפתרון</h2>
        <div class="code-box">
            <div class="code-label">C# — Number Guessing Game</div>
            <pre><span class="code-keyword">using</span> System;

<span class="code-keyword">class</span> Program
{
    <span class="code-keyword">static void</span> Main()
    {
        <span class="code-keyword">int</span> targetNumber = 42;
        <span class="code-keyword">int</span> guess = 0;
        <span class="code-keyword">int</span> attempts = 0;

        Console.WriteLine(<span class="code-string">"ניחוש מספר! נסי לנחש מספר בין 1 ל-50"</span>);

        <span class="code-keyword">while</span>(guess != targetNumber)
        {
            Console.WriteLine(<span class="code-string">"הכניסי ניחוש:"</span>);
            guess = int.Parse(Console.ReadLine());
            attempts++;

            <span class="code-keyword">if</span>(guess > targetNumber)
            {
                Console.WriteLine(<span class="code-string">"גבוה מדי! נסי שוב"</span>);
            }
            <span class="code-keyword">else if</span>(guess < targetNumber)
            {
                Console.WriteLine(<span class="code-string">"נמוך מדי! נסי שוב"</span>);
            }
            <span class="code-keyword">else</span>
            {
                Console.WriteLine(<span class="code-string">"כל הכבוד! ניחשת נכון!"</span>);
            }
        }

        Console.WriteLine(<span class="code-string">"סיימת ב-"</span> + attempts + <span class="code-string">" ניחושים"</span>);
    }
}

