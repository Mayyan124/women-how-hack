        <div class="code-box">
            <div class="code-label">🐍 Python — שיעור 2</div>
            <pre><span class="code-comment"># יצירת משתנים מסוגים שונים</span>
<span class="code-type">name</span> = <span class="code-string">"Maayan"</span>      <span class="code-comment"># str — טקסט</span>
<span class="code-type">age</span> = <span class="code-string">18</span>            <span class="code-comment"># int — מספר שלם</span>
<span class="code-type">height</span> = <span class="code-string">1.65</span>        <span class="code-comment"># float — מספר עשרוני</span>
<span class="code-type">has_pet</span> = <span class="code-keyword">True</span>      <span class="code-comment"># bool — נכון/לא נכון</span>

<span class="code-comment"># הצגת המשתנים</span>
<span class="code-keyword">print</span>(<span class="code-string">"שם:"</span>, name)
<span class="code-keyword">print</span>(<span class="code-string">"גיל:"</span>, age)
<span class="code-keyword">print</span>(<span class="code-string">"גובה:"</span>, height)
<span class="code-keyword">print</span>(<span class="code-string">"יש חיית מחמד?"</span>, has_pet)

<span class="code-comment"># פלט:</span>
<span class="code-output"># שם: Maayan
# גיל: 18
# גובה: 1.65
# יש חיית מחמד? True</span></pre>
