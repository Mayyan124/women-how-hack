            <p>5. איזה סוג נתון מתאים לשם "Maayan"?</p>
            <div class="quiz-options">
                <button class="quiz-btn" onclick="answer(this,'q5',false)">A) int</button>
                <button class="quiz-btn" onclick="answer(this,'q5',false)">B) float</button>
                <button class="quiz-btn" onclick="answer(this,'q5',true)">C) str ✅</button>
                <button class="quiz-btn" onclick="answer(this,'q5',false)">D) bool</button>
            </div>
            <div class="quiz-feedback" id="fb-q5"></div>
        </div>

        <div class="quiz-score" id="quiz-score"></div>
        <button class="quiz-submit" onclick="showScore()">בדקי תוצאות 🎀</button>
    </div>

    <div class="lesson-nav-btns">
        <a href="/courses/languages/python/lesson1" class="nav-btn">
            <div class="nav-arrow">→</div>
            <div class="nav-btn-text" style="text-align:right;">
                <p>← השיעור הקודם</p>
                <h3>שיעור 1 — היכרות עם Python</h3>
            </div>
        </a>
        <a href="/courses/languages/python/lesson3" class="nav-btn">
            <div class="nav-btn-text">
                <p>השיעור הבא ←</p>
                <h3>שיעור 3 — קלט ופלט 🎤</h3>
            </div>
            <div class="nav-arrow">←</div>
        </a>
    </div>

</div>

<script>
    document.getElementById('hamburger').onclick = function() { document.getElementById('nav-links').classList.toggle('open'); };
    const feedbacks = {
        q1: { ok: '✅ נכון! משתנה הוא מקום בזיכרון לשמירת מידע.', no: '❌ לא. משתנה הוא מקום בזיכרון לשמירת מידע.' },
        q2: { ok: '✅ מעולה! int הוא מספר שלם.', no: '❌ לא. int הוא מספר שלם ללא נקודה.' },
        q3: { ok: '✅ נכון! 1.65 הוא מספר עשרוני = float.', no: '❌ לא. 1.65 הוא float — מספר עם נקודה עשרונית.' },
        q4: { ok: '✅ בדיוק! bool הוא True או False בלבד.', no: '❌ לא. bool הוא True או False.' },
        q5: { ok: '✅ נכון! טקסט כמו שם הוא str.', no: '❌ לא. שם הוא טקסט = str.' },
    };
    const answers = {};
    function answer(btn, q, correct) {
        const btns = btn.closest('.quiz-options').querySelectorAll('.quiz-btn');
        btns.forEach(b => b.disabled = true);
        btn.classList.add(correct ? 'correct' : 'wrong');
        answers[q] = correct;
        const fb = document.getElementById('fb-' + q);
        fb.textContent = correct ? feedbacks[q].ok : feedbacks[q].no;
        fb.className = 'quiz-feedback show ' + (correct ? 'ok' : 'no');
    }
    function showScore() {
        const score = Object.values(answers).filter(Boolean).length;
        const el = document.getElementById('quiz-score');
        const emoji = score === 5 ? '🏆' : score >= 4 ? '🎀' : score >= 3 ? '💪' : '📚';
        const msg = score === 5 ? 'מושלם! את מוכנה לשיעור הבא!' : score >= 4 ? 'כמעט מושלם!' : score >= 3 ? 'יפה! כדאי לחזור על החומר.' : 'בואי נקרא שוב 💪';
        el.innerHTML = `<h3>${emoji} ${score}/5</h3><p>${msg}</p>`;
        el.style.display = 'block';
        el.scrollIntoView({ behavior: 'smooth' });
    }
    document.querySelectorAll('.lesson-nav a').forEach(a => {
        a.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) target.scrollIntoView({ behavior: 'smooth' });
            document.querySelectorAll('.lesson-nav a').forEach(x => x.classList.remove('active'));
            this.classList.add('active');
        });
    });
</script>
</body>
</html>
