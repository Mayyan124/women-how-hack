<script>
    document.getElementById('hamburger').onclick=function(){document.getElementById('nav-links').classList.toggle('open');};
    const feedbacks={q1:{ok:'✅ נכון! IP = כתובת ייחודית.',no:'❌ לא. IP היא כתובת ייחודית של כל מחשב ברשת.'},q2:{ok:'✅ מעולה! HTTPS = פורט 443.',no:'❌ לא. HTTPS משתמש בפורט 443 (80 = HTTP רגיל).'},q3:{ok:'✅ נכון! DNS מתרגם שמות לכתובות IP.',no:'❌ לא. DNS = Domain Name System, מתרגם google.com לכתובת IP.'},q4:{ok:'✅ בדיוק! Socket = חיבור בין שני מחשבים.',no:'❌ לא. Socket הוא חיבור (כמו שפופרת) בין שני מחשבים.'},q5:{ok:'✅ נכון! gethostbyname מחזירה IP של דומיין.',no:'❌ לא. gethostbyname() מחזירה את כתובת ה-IP של שם דומיין.'}};
    const answers={};
    function answer(btn,q,correct){const btns=btn.closest('.quiz-options').querySelectorAll('.quiz-btn');btns.forEach(b=>b.disabled=true);btn.classList.add(correct?'correct':'wrong');answers[q]=correct;const fb=document.getElementById('fb-'+q);fb.textContent=correct?feedbacks[q].ok:feedbacks[q].no;fb.className='quiz-feedback show '+(correct?'ok':'no');}
    function showScore(){const score=Object.values(answers).filter(Boolean).length;const el=document.getElementById('quiz-score');const emoji=score===5?'🏆':score>=4?'🎀':score>=3?'💪':'📚';el.innerHTML=`<h3>${emoji} ${score}/5</h3><p>${score===5?'האקרית רשתות! 🏆':score>=3?'יפה! חזרי על החומר.':'בואי נקרא שוב 💪'}</p>`;el.style.display='block';el.scrollIntoView({behavior:'smooth'});}
    document.querySelectorAll('.lesson-nav a').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth'});document.querySelectorAll('.lesson-nav a').forEach(x=>x.classList.remove('active'));this.classList.add('active');});});
</script>
</body>
</html>
