    <div class="lesson-section" id="code">
        <div class="section-title-row"><div class="section-icon">💻</div><h2 style="color:#7B1FA2;">דוגמת קוד</h2></div>
        <div class="code-box">
            <div class="code-label">🌐 Python — Networks</div>
            <pre><span class="code-keyword">import</span> socket

<span class="code-comment"># מציאת IP של דומיין</span>
domain = <span class="code-string">"google.com"</span>
ip = socket.gethostbyname(domain)
<span class="code-keyword">print</span>(<span class="code-string">f"IP של {domain}: {ip}"</span>)
<span class="code-output"># IP של google.com: 142.250.185.14</span>

<span class="code-comment"># מציאת שם המחשב שלך</span>
hostname = socket.gethostname()
my_ip = socket.gethostbyname(hostname)
<span class="code-keyword">print</span>(<span class="code-string">f"שם המחשב: {hostname}"</span>)
<span class="code-keyword">print</span>(<span class="code-string">f"IP שלי: {my_ip}"</span>)

<span class="code-comment"># בדיקת חיבור בסיסית לפורט</span>
<span class="code-keyword">def</span> check_port(host, port):
    sock = socket.socket()
    sock.settimeout(1)
    result = sock.connect_ex((host, port))
    sock.close()
    <span class="code-keyword">return</span> result == 0  <span class="code-comment"># True = פתוח</span>

<span class="code-keyword">if</span> check_port(<span class="code-string">"google.com"</span>, 443):
    <span class="code-keyword">print</span>(<span class="code-string">"פורט 443 פתוח ✅"</span>)
<span class="code-keyword">else</span>:
    <span class="code-keyword">print</span>(<span class="code-string">"פורט סגור ❌"</span>)</pre>
        </div>
    </div>
