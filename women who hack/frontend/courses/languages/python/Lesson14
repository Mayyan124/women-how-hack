    <div class="lesson-section" id="code">
        <div class="section-title-row"><div class="section-icon">💻</div><h2 style="color:#2E7D32;">דוגמת קוד — כלי Recon בסיסי</h2></div>
        <div class="code-box">
            <div class="code-label">🛡️ Python — Ethical Hacking Recon</div>
            <pre><span class="code-keyword">import</span> socket
<span class="code-keyword">import</span> datetime

<span class="code-comment"># כלי Reconnaissance בסיסי</span>
<span class="code-keyword">def</span> recon(target):
    <span class="code-keyword">print</span>(<span class="code-string">f"🔍 סריקת: {target}"</span>)
    <span class="code-keyword">print</span>(<span class="code-string">f"📅 {datetime.datetime.now()}"</span>)
    <span class="code-keyword">print</span>(<span class="code-string">"-" * 40</span>)
    
    <span class="code-comment"># מציאת IP</span>
    <span class="code-keyword">try</span>:
        ip = socket.gethostbyname(target)
        <span class="code-keyword">print</span>(<span class="code-string">f"✅ IP: {ip}"</span>)
    <span class="code-keyword">except</span>:
        <span class="code-keyword">print</span>(<span class="code-string">"❌ לא ניתן למצוא IP"</span>)
        <span class="code-keyword">return</span>
    
    <span class="code-comment"># בדיקת פורטים נפוצים</span>
    common_ports = {80:<span class="code-string">"HTTP"</span>, 443:<span class="code-string">"HTTPS"</span>, 22:<span class="code-string">"SSH"</span>, 21:<span class="code-string">"FTP"</span>}
    <span class="code-keyword">print</span>(<span class="code-string">"\n🚪 בדיקת פורטים:"</span>)
    <span class="code-keyword">for</span> port, name <span class="code-keyword">in</span> common_ports.items():
        sock = socket.socket()
        sock.settimeout(0.5)
        result = sock.connect_ex((ip, port))
        sock.close()
        status = <span class="code-string">"✅ פתוח"</span> <span class="code-keyword">if</span> result == 0 <span class="code-keyword">else</span> <span class="code-string">"❌ סגור"</span>
        <span class="code-keyword">print</span>(<span class="code-string">f"  פורט {port} ({name}): {status}"</span>)

<span class="code-comment"># הרצה — רק על מחשב שלך או בסביבת בדיקה!</span>
recon(<span class="code-string">"localhost"</span>)</pre>
