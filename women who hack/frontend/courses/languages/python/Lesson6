    <div class="lesson-section" id="code">
        <div class="section-title-row"><div class="section-icon">💻</div><h2>דוגמת קוד</h2></div>
        <div class="code-box">
            <div class="code-label">🐍 Python — שיעור 6</div>
            <pre><span class="code-comment"># for loop — עם range</span>
<span class="code-keyword">for</span> i <span class="code-keyword">in</span> range(5):
    <span class="code-keyword">print</span>(<span class="code-string">"מספר:"</span>, i)
<span class="code-output"># מספר: 0, מספר: 1 ... מספר: 4</span>

<span class="code-comment"># for loop — על רשימה</span>
friends = [<span class="code-string">"נועה"</span>, <span class="code-string">"תמר"</span>, <span class="code-string">"איה"</span>]
<span class="code-keyword">for</span> friend <span class="code-keyword">in</span> friends:
    <span class="code-keyword">print</span>(<span class="code-string">"שלום"</span>, friend)

<span class="code-comment"># while loop</span>
i = 0
<span class="code-keyword">while</span> i &lt; 3:
    <span class="code-keyword">print</span>(<span class="code-string">"סבב מספר"</span>, i)
    i += 1  <span class="code-comment"># חשוב! בלי זה — לולאה אינסופית</span>

<span class="code-comment"># break — עצירה מוקדמת</span>
<span class="code-keyword">for</span> i <span class="code-keyword">in</span> range(10):
    <span class="code-keyword">if</span> i == 5:
        <span class="code-keyword">break</span>
    <span class="code-keyword">print</span>(i)  <span class="code-output"># ידפיס 0-4 בלבד</span>

<span class="code-comment"># continue — דילוג</span>
<span class="code-keyword">for</span> i <span class="code-keyword">in</span> range(5):
    <span class="code-keyword">if</span> i == 3:
        <span class="code-keyword">continue</span>
    <span class="code-keyword">print</span>(i)  <span class="code-output"># ידפיס 0,1,2,4 (ידלג על 3)</span></pre>
        </div>
    </div>
