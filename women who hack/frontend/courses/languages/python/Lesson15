    <div class="lesson-section" id="code">
        <div class="section-title-row"><div class="section-icon">💻</div><h2>קוד הפרויקט המלא</h2></div>
        <div class="code-box">
            <div class="code-label">🏆 Security Audit Tool — פרויקט סיום</div>
            <pre><span class="code-keyword">import</span> hashlib
<span class="code-keyword">import</span> datetime

<span class="code-comment"># 1. בדיקת חוזק סיסמה</span>
<span class="code-keyword">def</span> check_password_strength(password):
    score = 0
    issues = []
    <span class="code-keyword">if</span> len(password) >= 8: score += 1
    <span class="code-keyword">else</span>: issues.append(<span class="code-string">"קצר מ-8 תווים"</span>)
    <span class="code-keyword">if</span> <span class="code-keyword">any</span>(c.isupper() <span class="code-keyword">for</span> c <span class="code-keyword">in</span> password): score += 1
    <span class="code-keyword">else</span>: issues.append(<span class="code-string">"חסרה אות גדולה"</span>)
    <span class="code-keyword">if</span> <span class="code-keyword">any</span>(c.isdigit() <span class="code-keyword">for</span> c <span class="code-keyword">in</span> password): score += 1
    <span class="code-keyword">else</span>: issues.append(<span class="code-string">"חסר מספר"</span>)
    <span class="code-keyword">if</span> <span class="code-keyword">any</span>(c <span class="code-keyword">in</span> <span class="code-string">"!@#$%^&*"</span> <span class="code-keyword">for</span> c <span class="code-keyword">in</span> password): score += 1
    <span class="code-keyword">else</span>: issues.append(<span class="code-string">"חסר סימן מיוחד"</span>)
    levels = [<span class="code-string">"חלשה ❌"</span>, <span class="code-string">"חלשה ❌"</span>, <span class="code-string">"בינונית ⚠️"</span>, <span class="code-string">"חזקה ✅"</span>, <span class="code-string">"חזקה מאוד 🏆"</span>]
    <span class="code-keyword">return</span> levels[score], issues

<span class="code-comment"># 2. Hash סיסמה</span>
<span class="code-keyword">def</span> hash_password(password):
    <span class="code-keyword">return</span> hashlib.sha256(password.encode()).hexdigest()

<span class="code-comment"># 3. בדיקת URL</span>
<span class="code-keyword">def</span> check_url(url):
    risks = []
    <span class="code-keyword">if not</span> url.startswith(<span class="code-string">"https"</span>): risks.append(<span class="code-string">"⚠️ לא HTTPS"</span>)
    suspicious = [<span class="code-string">"login-"</span>, <span class="code-string">"verify-"</span>, <span class="code-string">"secure-"</span>, <span class="code-string">"0"</span>, <span class="code-string">"1"</span>]
    <span class="code-keyword">for</span> s <span class="code-keyword">in</span> suspicious:
        <span class="code-keyword">if</span> s <span class="code-keyword">in</span> url: risks.append(<span class="code-string">f"⚠️ מילה חשודה: {s}"</span>)
    <span class="code-keyword">return</span> risks

<span class="code-comment"># 4. יצירת דוח</span>
password = input(<span class="code-string">"הכניסי סיסמה לבדיקה: "</span>)
url = input(<span class="code-string">"הכניסי URL לבדיקה: "</span>)

strength, issues = check_password_strength(password)
hashed = hash_password(password)
url_risks = check_url(url)

report = <span class="code-string">f"""
=== Security Audit Report ===
תאריך: {datetime.datetime.now()}

סיסמה: {strength}
בעיות: {', '.join(issues) if issues else 'אין'}
Hash: {hashed}

URL: {url}
סיכונים: {', '.join(url_risks) if url_risks else '✅ נראה בטוח'}
"""</span>

<span class="code-keyword">with</span> open(<span class="code-string">"security_report.txt"</span>, <span class="code-string">"w"</span>, encoding=<span class="code-string">"utf-8"</span>) <span class="code-keyword">as</span> f:
    f.write(report)

<span class="code-keyword">print</span>(report)
<span class="code-keyword">print</span>(<span class="code-string">"✅ הדוח נשמר ב-security_report.txt"</span>)</pre>
