    <span class="code-keyword">return</span> <span class="code-keyword">any</span>(word <span class="code-keyword">in</span> url.lower() <span class="code-keyword">for</span> word <span class="code-keyword">in</span> suspicious)

url = <span class="code-string">"http://gmai1.com/login-verify"</span>
<span class="code-keyword">if</span> is_suspicious_url(url):
