    const feedbacks={q1:{ok:'✅ נכון! SQL Injection = קוד SQL זדוני בקלט.',no:'❌ לא. SQL Injection = הכנסת קוד SQL לשדה קלט כדי לגשת לבסיס הנתונים.'},q2:{ok:'✅ מעולה! XSS = JavaScript זדוני באתר.',no:'❌ לא. XSS = Cross-Site Scripting, הכנסת JavaScript זדוני שרץ בדפדפן.'},q3:{ok:'✅ נכון! Phishing = אתר מזויף.',no:'❌ לא. Phishing = יצירת אתר מזויף שמתחזה לאמיתי כדי לגנוב פרטים.'},q4:{ok:'✅ בדיוק! Parameterized Query מגן מ-SQL Injection.',no:'❌ לא. Parameterized Query מגן ספציפית מ-SQL Injection.'},q5:{ok:'✅ נכון! כתובת URL חשודה = סימן לPhishing.',no:'❌ לא. הסימן הכי ברור לPhishing הוא כתובת URL שגויה או חשודה.'}};
    const answers={};
    function answer(btn,q,correct){const btns=btn.closest('.quiz-options').querySelectorAll('.quiz-btn');btns.forEach(b=>b.disabled=true);btn.classList.add(correct?'correct':'wrong');answers[q]=correct;const fb=document.getElementById('fb-'+q);fb.textContent=correct?feedbacks[q].ok:feedbacks[q].no;fb.className='quiz-feedback show '+(correct?'ok':'no');}
    function showScore(){const score=Object.values(answers).filter(Boolean).length;const el=document.getElementById('quiz-score');const emoji=score===5?'🏆':score>=4?'🎀':score>=3?'💪':'📚';el.innerHTML=`<h3>${emoji} ${score}/5</h3><p>${score===5?'מגינת אתרים! 🏆':score>=3?'יפה! חזרי על החומר.':'בואי נקרא שוב 💪'}</p>`;el.style.display='block';el.scrollIntoView({behavior:'smooth'});}
    document.querySelectorAll('.lesson-nav a').forEach(a=>{a.addEventListener('click',function(e){e.preventDefault();const t=document.querySelector(this.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth'});document.querySelectorAll('.lesson-nav a').forEach(x=>x.classList.remove('active'));this.classList.add('active');});});
</script>
</body>
</html>
