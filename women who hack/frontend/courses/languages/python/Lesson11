    <div class="lesson-section" id="code">
        <div class="section-title-row"><div class="section-icon">💻</div><h2 style="color:#7B1FA2;">דוגמת קוד</h2></div>
        <div class="code-box">
            <div class="code-label">🔐 Python — Caesar Cipher</div>
            <pre><span class="code-comment"># הצפנת Caesar Cipher</span>
<span class="code-keyword">def</span> caesar_encrypt(text, key):
    result = <span class="code-string">""</span>
    <span class="code-keyword">for</span> char <span class="code-keyword">in</span> text:
        <span class="code-keyword">if</span> char.isalpha():
            shifted = ord(char.upper()) + key
            <span class="code-keyword">if</span> shifted > ord(<span class="code-string">'Z'</span>):
                shifted -= 26
            result += chr(shifted)
        <span class="code-keyword">else</span>:
            result += char
    <span class="code-keyword">return</span> result

<span class="code-comment"># פענוח — אותה פונקציה עם מפתח שלילי</span>
<span class="code-keyword">def</span> caesar_decrypt(text, key):
    <span class="code-keyword">return</span> caesar_encrypt(text, -key)

<span class="code-comment"># שימוש</span>
message = <span class="code-string">"HELLO"</span>
encrypted = caesar_encrypt(message, 3)
decrypted = caesar_decrypt(encrypted, 3)

<span class="code-keyword">print</span>(<span class="code-string">f"מקורי: {message}"</span>)    <span class="code-output"># HELLO</span>
<span class="code-keyword">print</span>(<span class="code-string">f"מוצפן: {encrypted}"</span>)  <span class="code-output"># KHOOR</span>
<span class="code-keyword">print</span>(<span class="code-string">f"מפוענח: {decrypted}"</span>) <span class="code-output"># HELLO</span>

<span class="code-comment"># Hash עם Python</span>
<span class="code-keyword">import</span> hashlib
password = <span class="code-string">"mypassword"</span>
hashed = hashlib.md5(password.encode()).hexdigest()
<span class="code-keyword">print</span>(<span class="code-string">f"Hash: {hashed}"</span>)</pre>
        </div>
